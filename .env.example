# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key — get one free at https://console.groq.com
# Used for chat completions (Llama 3) and Whisper audio transcription
GROQ_API_KEY=groq_key

# Secret used to sign JWT tokens — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_me_to_a_long_random_secret

# ── Database ──────────────────────────────────────────────────────────────────

# These are used by both docker-compose.yml and the backend
POSTGRES_USER=aitalker
POSTGRES_PASSWORD=aitalker_secret
POSTGRES_DB=aitalker

# Full async DSN used by SQLAlchemy (auto-constructed in docker-compose from above)
# Override here only if you're running the backend outside Docker:
DATABASE_URL=postgresql+asyncpg://aitalker:aitalker_secret@localhost:5432/aitalker

# ── Redis ─────────────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0

# ── Optional overrides ────────────────────────────────────────────────────────

# Set to "true" to enable SQLAlchemy query logging and detailed error responses
DEBUG=false

# Groq chat model for Q&A and summarisation
# Available: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Groq Whisper model for audio/video transcription
# Available: whisper-large-v3, whisper-large-v3-turbo, distil-whisper-large-v3-en
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Local sentence-transformers model for FAISS embeddings (downloaded automatically, no API key)
# Smaller alternative: paraphrase-MiniLM-L3-v2 | Larger: all-mpnet-base-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# JWT expiry settings
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Maximum upload size in megabytes
MAX_UPLOAD_SIZE_MB=100

# Number of similar chunks to retrieve per Q&A query
RETRIEVAL_TOP_K=5

# Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
